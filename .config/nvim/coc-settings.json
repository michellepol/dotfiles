{
    "clangd.arguments": [
        "--background-index",
        "--header-insertion=never",
        "--clang-tidy",
        "-j=8"
    ],
    "clangd.path": "/usr/bin/clangd",
    "diagnostic.checkCurrentLine": true,
    "coc.preferences.useQuickfixForLocations": true,
    "coc.preferences.formatOnSave": true,
    "basedpyright.enable": true,
    "basedpyright.analysis.typeCheckingMode": "standard",
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Path": "/Library/Frameworks/Python.framework/Versions/3.7/bin/flake8",
    "python.linting.flake8Args": [
        "--ignore=E501"
    ],
    "python.linting.pep8Enabled": true,
    "python.linting.pep8Path": "/Library/Frameworks/Python.framework/Versions/3.7/bin/pep8",
    "python.linting.pep8Args": [
        "--ignore=E501,E0401,E701"
    ],
    "python.analysis.diagnosticEnabled": false,
    "python.formatting.autopep8Path": "/Library/Frameworks/Python.framework/Versions/3.7/bin/autopep8"
}
